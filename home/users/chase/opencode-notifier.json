{
  "sound": false,
  "notification": false,
  "timeout": 5,
  "showProjectName": true,
  "showSessionTitle": false,
  "showIcon": true,
  "linux": {
    "grouping": false
  },
  "command": {
    "enabled": true,
    "path": "/opt/orbstack-guest/bin/mac",
    "args": ["bash", "-c", "afplay /System/Library/Sounds/Glass.aiff"],
    "minDuration": 0
  },
  "events": {
    "permission": { "sound": true, "notification": false },
    "complete": { "sound": true, "notification": false },
    "subagent_complete": { "sound": false, "notification": false },
    "error": { "sound": true, "notification": false },
    "question": { "sound": true, "notification": false },
    "user_cancelled": { "sound": false, "notification": false }
  },
  "messages": {
    "permission": "Session needs permission: {sessionTitle}",
    "complete": "Session has finished: {sessionTitle}",
    "subagent_complete": "Subagent task completed: {sessionTitle}",
    "error": "Session encountered an error: {sessionTitle}",
    "question": "Session has a question: {sessionTitle}",
    "user_cancelled": "Session was cancelled by user: {sessionTitle}"
  },
  "sounds": {
    "permission": null,
    "complete": null,
    "subagent_complete": null,
    "error": null,
    "question": null,
    "user_cancelled": null
  },
  "volumes": {
    "permission": 1,
    "complete": 1,
    "subagent_complete": 1,
    "error": 1,
    "question": 1,
    "user_cancelled": 1
  }
}
