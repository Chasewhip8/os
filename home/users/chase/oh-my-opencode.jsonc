{
    "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
    "agents": {
        "sisyphus": {
            "model": "anthropic/claude-opus-4-6",
            "variant": "max",
        },
        "oracle": {
            "model": "openai/gpt-5.4",
            "variant": "xhigh",
        },
        "librarian": {
            "model": "anthropic/claude-sonnet-4-6",
        },
        "explore": {
            "model": "openai/gpt-5.3-codex-spark",
            "variant": "medium",
        },
        "multimodal-looker": {
            "model": "openai/gpt-5.4",
        },
        "prometheus": {
            "model": "anthropic/claude-opus-4-6",
            "variant": "max",
        },
        "metis": {
            "model": "anthropic/claude-opus-4-6",
            "variant": "max",
        },
        "momus": {
            "model": "openai/gpt-5.4",
            "variant": "xhigh",
        },
    },
    "categories": {
        "visual-engineering": {
            "model": "anthropic/claude-opus-4-6",
            "variant": "max",
        },
        "ultrabrain": {
            "model": "openai/gpt-5.4",
            "variant": "xhigh",
        },
        "deep": {
            "model": "openai/gpt-5.4",
            "variant": "xhigh",
        },
        "artistry": {
            "model": "anthropic/claude-opus-4-6",
            "variant": "max",
        },
        "quick": {
            "model": "openai/gpt-5.4",
            "variant": "medium",
        },
        "unspecified-low": {
            "model": "openai/gpt-5.4",
            "variant": "xhigh",
        },
        "unspecified-high": {
            "model": "openai/gpt-5.4",
            "variant": "xhigh",
        },
        "writing": {
            "model": "anthropic/claude-sonnet-4-6",
        },
    },
    "lsp": {
        "marksman": {
            "command": ["marksman", "server"],
            "extensions": [".md", ".markdown"],
        },
        "taplo": {
            "command": ["taplo", "lsp", "stdio"],
            "extensions": [".toml"],
        },
    },
    "experimental": {
        "disable_omo_env": true,
    },
}
